diff --git a/fuzz/scripts/cmin.sh b/fuzz/scripts/cmin.sh
new file mode 100755
index 0000000..6b3e35e
--- /dev/null
+++ b/fuzz/scripts/cmin.sh
@@ -0,0 +1,26 @@
+#!/usr/bin/env bash
+# Minimize a fuzz corpus with afl-cmin. Replaces fuzz/corpus/<target>/
+# with the minimized set, preserving from-tests/ and seed-* files.
+#
+# Usage: ./fuzz/scripts/cmin.sh <harness-name>
+set -euo pipefail
+
+if [ $# -lt 1 ]; then
+  echo "usage: $0 <harness-name>" >&2
+  exit 2
+fi
+
+harness="${1#fuzz/}"
+target_short="${harness#fuzz-}"
+bin="fuzz/${harness}"
+src="fuzz/corpus/${target_short}"
+dst="fuzz/corpus/${target_short}.cmin"
+
+if [ ! -x "$bin" ]; then echo "$bin not built" >&2; exit 1; fi
+if [ ! -d "$src" ]; then echo "$src missing" >&2; exit 1; fi
+
+rm -rf "$dst"
+afl-cmin -i "$src" -o "$dst" -t 1000 -m none -- "$bin"
+echo
+echo "Minimized into $dst (orig: $(find "$src" -type f | wc -l), min: $(find "$dst" -type f | wc -l))."
+echo "Apply: rm -rf $src && mv $dst $src"
diff --git a/fuzz/scripts/run.sh b/fuzz/scripts/run.sh
new file mode 100755
index 0000000..409e9d0
--- /dev/null
+++ b/fuzz/scripts/run.sh
@@ -0,0 +1,59 @@
+#!/usr/bin/env bash
+# Launch a single fuzz harness under afl-fuzz.
+#
+# Usage:
+#   ./fuzz/scripts/run.sh <harness-name> [duration]
+#   ./fuzz/scripts/run.sh fuzz-metadata
+#   ./fuzz/scripts/run.sh fuzz-metadata 4h
+#
+# Defaults to running until Ctrl-C if no duration is given.
+set -euo pipefail
+
+if [ $# -lt 1 ]; then
+  echo "usage: $0 <harness-name> [duration]" >&2
+  echo "  harness-name: one of fuzz-{ref,oci-versioned,oci-image,repofile,filter,metadata,oci-registry-local,smoke}" >&2
+  exit 2
+fi
+
+harness="$1"
+duration="${2:-}"
+
+# Strip optional fuzz/ prefix.
+harness="${harness#fuzz/}"
+
+bin="fuzz/${harness}"
+target_short="${harness#fuzz-}"
+
+# Map harness name to corpus + dict.
+corpus="fuzz/corpus/${target_short}"
+case "$target_short" in
+  oci-versioned|oci-image|oci-registry-local) dict="fuzz/dict/oci.dict" ;;
+  repofile|filter|metadata)                   dict="fuzz/dict/keyfile.dict" ;;
+  ref)                                        dict="fuzz/dict/ref.dict" ;;
+  *)                                          dict="" ;;
+esac
+
+if [ ! -x "$bin" ]; then
+  echo "$bin not found or not executable. Run 'make $bin' first." >&2
+  exit 1
+fi
+
+if [ ! -d "$corpus" ]; then
+  echo "$corpus not found." >&2
+  exit 1
+fi
+
+out="fuzz/out/${target_short}"
+mkdir -p "$out"
+
+args=(-i "$corpus" -o "$out" -t 1000 -m none)
+[ -n "$dict" ] && [ -f "$dict" ] && args+=(-x "$dict")
+[ -n "$duration" ] && args+=(-V "$duration")
+
+# AFL-side env: persistent mode is auto-detected via the binary's symbols.
+export AFL_AUTORESUME=1
+export AFL_SKIP_CPUFREQ=1
+export AFL_DISABLE_TRIM=0
+
+echo "Running: afl-fuzz ${args[*]} -- $bin"
+exec afl-fuzz "${args[@]}" -- "$bin"
diff --git a/fuzz/scripts/seed-from-tests.sh b/fuzz/scripts/seed-from-tests.sh
new file mode 100755
index 0000000..4962d10
--- /dev/null
+++ b/fuzz/scripts/seed-from-tests.sh
@@ -0,0 +1,53 @@
+#!/usr/bin/env bash
+# Harvest additional fuzz seeds from a previously-run test suite.
+#
+# Usage:
+#   1. Run: TEST_SKIP_CLEANUP=1 make check TESTS=tests/test-oci-registry.sh.test
+#      (or any subset). The .testtmp dirs under tests/ remain populated.
+#   2. From the build directory: ./fuzz/scripts/seed-from-tests.sh
+#
+# Adds files into fuzz/corpus/<target>/from-tests/ — separate from the
+# checked-in seeds so users can wipe them without losing the canonical
+# minimum.
+set -euo pipefail
+
+if [ ! -d tests ]; then
+  echo "Run from the flatpak-1.12.9 build directory (with tests/)." >&2
+  exit 2
+fi
+
+CORPUS_ROOT="${CORPUS_ROOT:-fuzz/corpus}"
+
+mkdir -p "$CORPUS_ROOT"/{ref,oci-versioned,oci-image,repofile,filter,metadata,oci-registry-local}/from-tests
+
+count_before=$(find "$CORPUS_ROOT" -type f -name 'from-tests*' 2>/dev/null | wc -l)
+
+# Metadata files from app/runtime test fixtures.
+find tests -name 'metadata' -type f 2>/dev/null | head -20 | while read -r f; do
+  dst="$CORPUS_ROOT/metadata/from-tests/$(echo "$f" | tr '/' '_')"
+  cp -f "$f" "$dst"
+done
+
+# .flatpakrepo files from remote test fixtures.
+find tests -name '*.flatpakrepo' -type f 2>/dev/null | head -20 | while read -r f; do
+  dst="$CORPUS_ROOT/repofile/from-tests/$(echo "$f" | tr '/' '_')"
+  cp -f "$f" "$dst"
+done
+
+# OCI manifests and image configs from the OCI registry test server.
+find tests -path '*oci*' -name '*.json' -type f 2>/dev/null | head -40 | while read -r f; do
+  # Heuristic: files mentioning "image.manifest" or "image.index" go to oci-versioned;
+  # files mentioning "image.config" go to oci-image.
+  if grep -lq 'image.manifest\|image.index' "$f" 2>/dev/null; then
+    dst="$CORPUS_ROOT/oci-versioned/from-tests/$(echo "$f" | tr '/' '_')"
+    # Prepend a selector byte (0x00) so the harness sees the file as input.
+    { printf '\x00'; cat "$f"; } > "$dst"
+  elif grep -lq 'image.config\|rootfs' "$f" 2>/dev/null; then
+    dst="$CORPUS_ROOT/oci-image/from-tests/$(echo "$f" | tr '/' '_')"
+    cp -f "$f" "$dst"
+  fi
+done
+
+count_after=$(find "$CORPUS_ROOT" -type f -path '*/from-tests/*' 2>/dev/null | wc -l)
+added=$((count_after - count_before))
+echo "Harvested $count_after seeds (+$added new) into $CORPUS_ROOT/*/from-tests/"
