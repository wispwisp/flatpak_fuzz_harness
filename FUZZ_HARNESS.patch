diff --git a/fuzz/Makefile.am.inc b/fuzz/Makefile.am.inc
new file mode 100644
index 0000000..6b2d062
--- /dev/null
+++ b/fuzz/Makefile.am.inc
@@ -0,0 +1,140 @@
+# AFL++ fuzz harnesses. Built only when --enable-fuzzing.
+# Each harness is a small C program defining LLVMFuzzerTestOneInput()
+# plus an AFL persistent-mode main(); harnesses link against the
+# libflatpak-common.la convenience archive.
+
+if ENABLE_FUZZING
+
+# Per-harness CPPFLAGS / CFLAGS additions on top of AM_CPPFLAGS / AM_CFLAGS.
+# AM_CPPFLAGS already provides -I paths to common/, subprojects/, libglnx/,
+# so we add only -DFLATPAK_COMPILATION (private headers) and the package
+# pkg-config CFLAGS the harnesses need.
+fuzz_common_cppflags = \
+	-DFLATPAK_COMPILATION \
+	$(BASE_CFLAGS) \
+	$(JSON_CFLAGS) \
+	$(OSTREE_CFLAGS) \
+	$(SOUP_CFLAGS) \
+	$(NULL)
+
+fuzz_common_libs = \
+	libflatpak-common.la \
+	libflatpak-common-base.la \
+	libglnx.la \
+	$(BASE_LIBS) \
+	$(JSON_LIBS) \
+	$(OSTREE_LIBS) \
+	$(SOUP_LIBS) \
+	$(ARCHIVE_LIBS) \
+	$(ZSTD_LIBS) \
+	$(INTERNAL_GPGME_LIBS) \
+	$(LIBSECCOMP_LIBS) \
+	$(MALCONTENT_LIBS) \
+	$(POLKIT_LIBS) \
+	$(SYSTEMD_LIBS) \
+	$(XAUTH_LIBS) \
+	$(XML_LIBS) \
+	$(NULL)
+
+fuzz_fuzz_smoke_SOURCES = \
+	fuzz/fuzz-common.c \
+	fuzz/fuzz-common.h \
+	fuzz/fuzz-smoke.c \
+	$(NULL)
+fuzz_fuzz_smoke_CFLAGS = $(AM_CFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_smoke_CPPFLAGS = $(AM_CPPFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_smoke_LDADD = $(fuzz_common_libs)
+
+noinst_PROGRAMS += fuzz/fuzz-smoke
+
+fuzz_fuzz_ref_SOURCES = \
+	fuzz/fuzz-common.c \
+	fuzz/fuzz-common.h \
+	fuzz/fuzz-ref.c \
+	$(NULL)
+fuzz_fuzz_ref_CFLAGS = $(AM_CFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_ref_CPPFLAGS = $(AM_CPPFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_ref_LDADD = $(fuzz_common_libs)
+
+noinst_PROGRAMS += fuzz/fuzz-ref
+
+fuzz_fuzz_oci_versioned_SOURCES = \
+	fuzz/fuzz-common.c \
+	fuzz/fuzz-common.h \
+	fuzz/fuzz-oci-versioned.c \
+	$(NULL)
+fuzz_fuzz_oci_versioned_CFLAGS = $(AM_CFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_oci_versioned_CPPFLAGS = $(AM_CPPFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_oci_versioned_LDADD = $(fuzz_common_libs)
+
+noinst_PROGRAMS += fuzz/fuzz-oci-versioned
+
+fuzz_fuzz_oci_image_SOURCES = \
+	fuzz/fuzz-common.c \
+	fuzz/fuzz-common.h \
+	fuzz/fuzz-oci-image.c \
+	$(NULL)
+fuzz_fuzz_oci_image_CFLAGS = $(AM_CFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_oci_image_CPPFLAGS = $(AM_CPPFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_oci_image_LDADD = $(fuzz_common_libs)
+
+noinst_PROGRAMS += fuzz/fuzz-oci-image
+
+fuzz_fuzz_repofile_SOURCES = \
+	fuzz/fuzz-common.c \
+	fuzz/fuzz-common.h \
+	fuzz/fuzz-repofile.c \
+	$(NULL)
+fuzz_fuzz_repofile_CFLAGS = $(AM_CFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_repofile_CPPFLAGS = $(AM_CPPFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_repofile_LDADD = $(fuzz_common_libs)
+
+noinst_PROGRAMS += fuzz/fuzz-repofile
+
+fuzz_fuzz_filter_SOURCES = \
+	fuzz/fuzz-common.c \
+	fuzz/fuzz-common.h \
+	fuzz/fuzz-filter.c \
+	$(NULL)
+fuzz_fuzz_filter_CFLAGS = $(AM_CFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_filter_CPPFLAGS = $(AM_CPPFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_filter_LDADD = $(fuzz_common_libs)
+
+noinst_PROGRAMS += fuzz/fuzz-filter
+
+fuzz_fuzz_metadata_SOURCES = \
+	fuzz/fuzz-common.c \
+	fuzz/fuzz-common.h \
+	fuzz/fuzz-metadata.c \
+	$(NULL)
+fuzz_fuzz_metadata_CFLAGS = $(AM_CFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_metadata_CPPFLAGS = $(AM_CPPFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_metadata_LDADD = $(fuzz_common_libs)
+
+noinst_PROGRAMS += fuzz/fuzz-metadata
+
+fuzz_fuzz_oci_registry_local_SOURCES = \
+	fuzz/fuzz-common.c \
+	fuzz/fuzz-common.h \
+	fuzz/fuzz-oci-registry-local.c \
+	$(NULL)
+fuzz_fuzz_oci_registry_local_CFLAGS = $(AM_CFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_oci_registry_local_CPPFLAGS = $(AM_CPPFLAGS) $(fuzz_common_cppflags)
+fuzz_fuzz_oci_registry_local_LDADD = $(fuzz_common_libs)
+
+noinst_PROGRAMS += fuzz/fuzz-oci-registry-local
+
+EXTRA_DIST += \
+	fuzz/README.md \
+	$(wildcard $(srcdir)/fuzz/dict/*.dict) \
+	$(wildcard $(srcdir)/fuzz/scripts/*.sh) \
+	$(wildcard $(srcdir)/fuzz/corpus/ref/*) \
+	$(wildcard $(srcdir)/fuzz/corpus/oci-versioned/*) \
+	$(wildcard $(srcdir)/fuzz/corpus/oci-image/*) \
+	$(wildcard $(srcdir)/fuzz/corpus/repofile/*) \
+	$(wildcard $(srcdir)/fuzz/corpus/filter/*) \
+	$(wildcard $(srcdir)/fuzz/corpus/metadata/*) \
+	$(wildcard $(srcdir)/fuzz/corpus/oci-registry-local/*) \
+	$(NULL)
+
+endif # ENABLE_FUZZING
diff --git a/fuzz/README.md b/fuzz/README.md
new file mode 100644
index 0000000..0079ab1
--- /dev/null
+++ b/fuzz/README.md
@@ -0,0 +1,15 @@
+# fuzz/ — AFL++ harnesses for Flatpak
+
+This directory is built only with `--enable-fuzzing`. See
+`../../docs/superpowers/specs/2026-05-08-flatpak-aflpp-fuzzing-design.md`
+for design context, and the "Fuzzing" section of the workspace
+`../../README.md` for the operational workflow.
+
+Layout:
+
+- `fuzz-*.c` — one harness per parser entry point.
+- `fuzz-common.{c,h}` — shared helpers.
+- `corpus/<target>/` — checked-in seed corpus (one minimal seed per
+  harness).
+- `dict/*.dict` — AFL++ dictionaries.
+- `scripts/` — `run.sh`, `cmin.sh`, `triage.sh`, `seed-from-tests.sh`.
