index 0000000..fe8c993
--- /dev/null
+++ b/fuzz/scripts/triage.sh
@@ -0,0 +1,38 @@
+#!/usr/bin/env bash
+# Triage a single AFL crash: minimize with afl-tmin and capture an
+# ASan-decorated stack trace.
+#
+# Usage: ./fuzz/scripts/triage.sh <harness-name> <crash-file>
+set -euo pipefail
+
+if [ $# -lt 2 ]; then
+  echo "usage: $0 <harness-name> <crash-file>" >&2
+  exit 2
+fi
+
+harness="${1#fuzz/}"
+target_short="${harness#fuzz-}"
+bin="fuzz/${harness}"
+crash="$2"
+
+if [ ! -x "$bin" ]; then echo "$bin not built" >&2; exit 1; fi
+if [ ! -f "$crash" ]; then echo "$crash missing" >&2; exit 1; fi
+
+triage_dir="fuzz/triage/${target_short}/$(basename "$crash")"
+mkdir -p "$triage_dir"
+min="$triage_dir/min"
+log="$triage_dir/asan.log"
+
+afl-tmin -i "$crash" -o "$min" -t 5000 -m none -- "$bin"
+
+# Re-run under ASan, capturing the abort stack.
+ASAN_OPTIONS="abort_on_error=1:halt_on_error=1:print_stacktrace=1:detect_leaks=0" \
+  "$bin" "$min" > "$log" 2>&1 || true
+
+echo
+echo "Triaged: $crash"
+echo "  Minimized: $min  ($(stat -c%s "$min") bytes)"
+echo "  ASan log: $log"
+echo
+echo "First 40 lines of ASan output:"
+head -40 "$log" || true
