diff --git a/fuzz/fuzz-common.c b/fuzz/fuzz-common.c
new file mode 100644
index 0000000..3324721
--- /dev/null
+++ b/fuzz/fuzz-common.c
@@ -0,0 +1,77 @@
+#include "config.h"
+#include "fuzz-common.h"
+
+#include <errno.h>
+#include <fcntl.h>
+#include <ftw.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <unistd.h>
+
+#include <gio/gio.h>
+
+char *
+fuzz_dup_cstring (const uint8_t *data, size_t size)
+{
+  if (size == 0)
+    return NULL;
+  return g_strndup ((const char *) data, size);
+}
+
+char *
+fuzz_sha256_hex (const uint8_t *data, size_t size)
+{
+  GChecksum *cs = g_checksum_new (G_CHECKSUM_SHA256);
+  g_checksum_update (cs, data, size);
+  char *hex = g_strdup (g_checksum_get_string (cs));
+  g_checksum_free (cs);
+  return hex;
+}
+
+char *
+fuzz_make_tmpdir (const char *name_template)
+{
+  /* g_dir_make_tmp wants a template ending in XXXXXX. */
+  char *full = g_strdup_printf ("%s-XXXXXX", name_template ? name_template : "fuzz");
+  GError *error = NULL;
+  char *path = g_dir_make_tmp (full, &error);
+  g_free (full);
+  if (path == NULL)
+    {
+      g_warning ("fuzz_make_tmpdir: %s", error ? error->message : "unknown");
+      g_clear_error (&error);
+      return NULL;
+    }
+  return path;
+}
+
+static int
+unlink_cb (const char *fpath, const struct stat *sb, int typeflag, struct FTW *ftwbuf)
+{
+  (void) sb; (void) typeflag; (void) ftwbuf;
+  return remove (fpath);
+}
+
+void
+fuzz_rm_rf (const char *path)
+{
+  if (path == NULL || path[0] == '\0')
+    return;
+  /* nopenfd=64: arbitrary, must be > 0. */
+  nftw (path, unlink_cb, 64, FTW_DEPTH | FTW_PHYS);
+}
+
+gboolean
+fuzz_write_file (const char *path, const uint8_t *data, size_t size)
+{
+  GError *error = NULL;
+  gboolean ok = g_file_set_contents (path, (const char *) data, (gssize) size, &error);
+  if (!ok)
+    {
+      g_warning ("fuzz_write_file %s: %s", path, error ? error->message : "unknown");
+      g_clear_error (&error);
+    }
+  return ok;
+}
diff --git a/fuzz/fuzz-common.h b/fuzz/fuzz-common.h
new file mode 100644
index 0000000..46c0511
--- /dev/null
+++ b/fuzz/fuzz-common.h
@@ -0,0 +1,97 @@
+/*
+ * Shared helpers for AFL++ fuzz harnesses.
+ *
+ * Each harness defines LLVMFuzzerTestOneInput() (libFuzzer-compatible
+ * signature) and uses FUZZ_AFL_PERSISTENT_MAIN() to wrap it in an
+ * AFL++ persistent-mode main(). Build with afl-clang-fast.
+ */
+#ifndef FUZZ_COMMON_H
+#define FUZZ_COMMON_H
+
+#include <stddef.h>
+#include <stdint.h>
+#include <glib.h>
+
+/* libFuzzer-compatible entry point each harness must define. */
+int LLVMFuzzerTestOneInput (const uint8_t *data, size_t size);
+
+/* Duplicate `data` (length `size`) as a NUL-terminated heap string.
+ * Returns NULL on size == 0 to keep harnesses simple. Caller g_free()s. */
+char * fuzz_dup_cstring (const uint8_t *data, size_t size);
+
+/* Compute lowercase-hex sha256 of `bytes` (length `size`). Caller g_free()s. */
+char * fuzz_sha256_hex (const uint8_t *data, size_t size);
+
+/* Create a unique tmpdir under /tmp and return its absolute path.
+ * Caller must rm -rf and g_free(). Returns NULL on failure (the
+ * harness should `abort()` if so — this is harness infrastructure,
+ * not the system under test). */
+char * fuzz_make_tmpdir (const char *name_template);
+
+/* Recursively rm -rf a directory. */
+void fuzz_rm_rf (const char *path);
+
+/* Write `data` (length `size`) to a file at `path` (full overwrite). */
+gboolean fuzz_write_file (const char    *path,
+                          const uint8_t *data,
+                          size_t         size);
+
+/*
+ * AFL++ persistent-mode main wrapper. Place at file scope of each harness:
+ *
+ *     #include "fuzz-common.h"
+ *     int LLVMFuzzerTestOneInput(const uint8_t *d, size_t s) { ... }
+ *     FUZZ_AFL_PERSISTENT_MAIN(10000)
+ *
+ * The argument is the persistent-loop iteration count (a typical value
+ * is 10000). When run outside AFL (e.g., to validate a single seed),
+ * the binary reads the input from argv[1] and exits.
+ */
+#ifdef __AFL_COMPILER
+/* Emitted at file scope of each harness via the macro below — must NOT
+ * appear in this header at top level, or every translation unit that
+ * #includes fuzz-common.h ends up defining __afl_sharedmem_fuzzing /
+ * __afl_fuzz_alt / __afl_fuzz_alt_ptr and link fails with multiple
+ * definitions. The macro body is at file scope when invoked, so the
+ * AFL globals land exactly once per binary. */
+#define FUZZ_AFL_PERSISTENT_MAIN(LOOPS)                               \
+  __AFL_FUZZ_INIT();                                                  \
+  int main (int argc, char **argv)                                    \
+  {                                                                   \
+    if (argc > 1)                                                     \
+      {                                                               \
+        gchar *contents = NULL;                                       \
+        gsize len = 0;                                                \
+        if (!g_file_get_contents (argv[1], &contents, &len, NULL))    \
+          return 2;                                                   \
+        LLVMFuzzerTestOneInput ((const uint8_t *) contents, len);     \
+        g_free (contents);                                            \
+        return 0;                                                     \
+      }                                                               \
+    __AFL_INIT();                                                     \
+    unsigned char *buf = __AFL_FUZZ_TESTCASE_BUF;                     \
+    while (__AFL_LOOP (LOOPS))                                        \
+      {                                                               \
+        int n = __AFL_FUZZ_TESTCASE_LEN;                              \
+        if (n <= 0) continue;                                         \
+        LLVMFuzzerTestOneInput (buf, (size_t) n);                     \
+      }                                                               \
+    return 0;                                                         \
+  }
+#else
+/* Non-AFL build: read input from argv[1] and exit. Useful for ASan repro. */
+#define FUZZ_AFL_PERSISTENT_MAIN(LOOPS)                               \
+  int main (int argc, char **argv)                                    \
+  {                                                                   \
+    gchar *contents = NULL;                                           \
+    gsize len = 0;                                                    \
+    if (argc < 2) return 2;                                           \
+    if (!g_file_get_contents (argv[1], &contents, &len, NULL))        \
+      return 2;                                                       \
+    LLVMFuzzerTestOneInput ((const uint8_t *) contents, len);         \
+    g_free (contents);                                                \
+    return 0;                                                         \
+  }
+#endif
+
+#endif /* FUZZ_COMMON_H */
diff --git a/fuzz/fuzz-filter.c b/fuzz/fuzz-filter.c
new file mode 100644
index 0000000..d3623aa
--- /dev/null
+++ b/fuzz/fuzz-filter.c
@@ -0,0 +1,28 @@
+#include "config.h"
+#include "fuzz-common.h"
+
+#include <glib.h>
+
+#include "flatpak-utils-private.h"
+
+int
+LLVMFuzzerTestOneInput (const uint8_t *data, size_t size)
+{
+  if (size == 0 || size > (1 << 18))
+    return 0;
+
+  g_autofree char *s = fuzz_dup_cstring (data, size);
+  if (s == NULL)
+    return 0;
+
+  GRegex *allow = NULL, *deny = NULL;
+  g_autoptr(GError) error = NULL;
+  flatpak_parse_filters (s, &allow, &deny, &error);
+
+  if (allow) g_regex_unref (allow);
+  if (deny) g_regex_unref (deny);
+
+  return 0;
+}
+
+FUZZ_AFL_PERSISTENT_MAIN (10000)
