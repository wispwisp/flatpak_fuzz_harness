diff --git a/fuzz/fuzz-oci-registry-local.c b/fuzz/fuzz-oci-registry-local.c
new file mode 100644
index 0000000..a70c3bc
--- /dev/null
+++ b/fuzz/fuzz-oci-registry-local.c
@@ -0,0 +1,113 @@
+#include "config.h"
+#include "fuzz-common.h"
+
+#include <glib.h>
+#include <gio/gio.h>
+
+#include "flatpak-oci-registry-private.h"
+#include "flatpak-json-oci-private.h"
+
+static gchar *
+build_uri (const char *path)
+{
+  GFile *f = g_file_new_for_path (path);
+  gchar *uri = g_file_get_uri (f);
+  g_object_unref (f);
+  return uri;
+}
+
+int
+LLVMFuzzerTestOneInput (const uint8_t *data, size_t size)
+{
+  /* All g_auto* variables declared up-front so the cleanup attributes
+   * always see a well-defined (NULL) value, even on early goto out. */
+  g_autofree char *tmpdir = NULL;
+  g_autofree char *layout_path = NULL;
+  g_autofree char *blobs_dir = NULL;
+  g_autofree char *digest_hex = NULL;
+  g_autofree char *blob_path = NULL;
+  g_autofree char *index_path = NULL;
+  g_autofree char *index_json = NULL;
+  g_autofree char *uri = NULL;
+  g_autofree char *digest_ref = NULL;
+  g_autoptr(GError) error = NULL;
+  g_autoptr(FlatpakOciRegistry) registry = NULL;
+
+  static const char layout[] = "{\"imageLayoutVersion\": \"1.0.0\"}";
+
+  if (size == 0 || size > (1 << 19))
+    return 0;
+
+  tmpdir = fuzz_make_tmpdir ("flatpak-fuzz-reg");
+  if (tmpdir == NULL)
+    return 0;
+
+  /* oci-layout */
+  layout_path = g_build_filename (tmpdir, "oci-layout", NULL);
+  if (!fuzz_write_file (layout_path, (const uint8_t *) layout, sizeof (layout) - 1))
+    goto out;
+
+  /* blobs/sha256/<digest> */
+  blobs_dir = g_build_filename (tmpdir, "blobs", "sha256", NULL);
+  if (g_mkdir_with_parents (blobs_dir, 0700) != 0)
+    goto out;
+  digest_hex = fuzz_sha256_hex (data, size);
+  blob_path = g_build_filename (blobs_dir, digest_hex, NULL);
+  if (!fuzz_write_file (blob_path, data, size))
+    goto out;
+
+  /* index.json — minimal but well-formed: reference the blob as a manifest. */
+  index_path = g_build_filename (tmpdir, "index.json", NULL);
+  index_json = g_strdup_printf (
+    "{\"schemaVersion\":2,\"manifests\":[{"
+      "\"mediaType\":\"application/vnd.oci.image.manifest.v1+json\","
+      "\"digest\":\"sha256:%s\","
+      "\"size\":%zu"
+    "}]}", digest_hex, size);
+  fuzz_write_file (index_path, (const uint8_t *) index_json, strlen (index_json));
+
+  /* Open the registry. */
+  uri = build_uri (tmpdir);
+  registry = flatpak_oci_registry_new (uri, FALSE, -1, NULL, &error);
+  if (registry == NULL)
+    goto out;
+
+  digest_ref = g_strdup_printf ("sha256:%s", digest_hex);
+
+  /* Drive the load. The first byte of the input doubles as a flavour
+   * selector, so every input shape is exercised by at least one
+   * load function over the corpus. */
+  switch (data[0] % 3)
+    {
+    case 0:
+      {
+        gsize out_size = 0;
+        FlatpakOciVersioned *v = flatpak_oci_registry_load_versioned (
+          registry, NULL, digest_ref, NULL, &out_size, NULL, &error);
+        if (v) g_object_unref (v);
+        break;
+      }
+    case 1:
+      {
+        gsize out_size = 0;
+        FlatpakOciImage *img = flatpak_oci_registry_load_image_config (
+          registry, NULL, digest_ref, NULL, &out_size, NULL, &error);
+        if (img) g_object_unref (img);
+        break;
+      }
+    case 2:
+      {
+        FlatpakOciIndex *idx = flatpak_oci_registry_load_index (
+          registry, NULL, &error);
+        if (idx) g_object_unref (idx);
+        break;
+      }
+    }
+
+out:
+  if (tmpdir != NULL)
+    fuzz_rm_rf (tmpdir);
+  return 0;
+}
+
+FUZZ_AFL_PERSISTENT_MAIN (1000)
diff --git a/fuzz/fuzz-oci-versioned.c b/fuzz/fuzz-oci-versioned.c
new file mode 100644
index 0000000..c952d34
--- /dev/null
+++ b/fuzz/fuzz-oci-versioned.c
@@ -0,0 +1,41 @@
+#include "config.h"
+#include "fuzz-common.h"
+
+#include <glib.h>
+#include <gio/gio.h>
+
+#include "flatpak-json-oci-private.h"
+
+static const char *content_type_for_byte (uint8_t b) {
+  switch (b % 4) {
+    case 0: return NULL;
+    case 1: return FLATPAK_OCI_MEDIA_TYPE_IMAGE_MANIFEST;
+    case 2: return FLATPAK_OCI_MEDIA_TYPE_IMAGE_INDEX;
+    case 3: return FLATPAK_DOCKER_MEDIA_TYPE_IMAGE_MANIFEST2;
+  }
+  return NULL;
+}
+
+int
+LLVMFuzzerTestOneInput (const uint8_t *data, size_t size)
+{
+  if (size < 2 || size > (1 << 20))
+    return 0;
+
+  const char *ct = content_type_for_byte (data[0]);
+  g_autoptr(GBytes) bytes = g_bytes_new (data + 1, size - 1);
+  g_autoptr(GError) error = NULL;
+
+  FlatpakOciVersioned *v = flatpak_oci_versioned_from_json (bytes, ct, &error);
+  if (v != NULL)
+    {
+      const char *mt = flatpak_oci_versioned_get_mediatype (v);
+      gint64 ver = flatpak_oci_versioned_get_version (v);
+      (void) mt; (void) ver;
+      g_object_unref (v);
+    }
+
+  return 0;
+}
+
+FUZZ_AFL_PERSISTENT_MAIN (10000)
diff --git a/fuzz/fuzz-ref.c b/fuzz/fuzz-ref.c
new file mode 100644
index 0000000..c01bc08
--- /dev/null
+++ b/fuzz/fuzz-ref.c
@@ -0,0 +1,47 @@
+#include "config.h"
+#include "fuzz-common.h"
+
+#include <glib.h>
+
+#include "flatpak-ref-utils-private.h"
+
+int
+LLVMFuzzerTestOneInput (const uint8_t *data, size_t size)
+{
+  if (size < 2 || size > 4096)
+    return 0;
+
+  uint8_t selector = data[0];
+  g_autofree char *s = fuzz_dup_cstring (data + 1, size - 1);
+  g_autoptr(GError) error = NULL;
+  FlatpakDecomposed *ref = NULL;
+
+  switch (selector % 3)
+    {
+    case 0:
+      ref = flatpak_decomposed_new_from_ref (s, &error);
+      break;
+    case 1:
+      ref = flatpak_decomposed_new_from_refspec (s, &error);
+      break;
+    case 2:
+      ref = flatpak_decomposed_new_from_col_ref (s, NULL, &error);
+      break;
+    }
+
+  if (ref != NULL)
+    {
+      g_autofree char *id = flatpak_decomposed_dup_id (ref);
+      g_autofree char *arch = flatpak_decomposed_dup_arch (ref);
+      g_autofree char *branch = flatpak_decomposed_dup_branch (ref);
+      g_autofree char *pref = flatpak_decomposed_dup_pref (ref);
+      g_autofree char *rid = flatpak_decomposed_dup_readable_id (ref);
+      const char *cid = flatpak_decomposed_get_collection_id (ref);
+      (void) id; (void) arch; (void) branch; (void) pref; (void) rid; (void) cid;
+      flatpak_decomposed_unref (ref);
+    }
+
+  return 0;
+}
+
+FUZZ_AFL_PERSISTENT_MAIN (10000)
